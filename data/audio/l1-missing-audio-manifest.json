    {
      "id": "l1c_l1_2_1",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¡Buenas noches! Bienvenidos. ¿Tienen reserva?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-2",
        "kind": "S5_DIALOG.carlos",
        "index": 1
      }
    },
    {
      "id": "l1c_l1_2_2",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "Aquí tienen. ¿Quieren ver el menú?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-2",
        "kind": "S5_DIALOG.carlos",
        "index": 2
      }
    },
    {
      "id": "l1c_l1_2_3",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Qué van a tomar?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-2",
        "kind": "S5_DIALOG.carlos",
        "index": 3
      }
    },
    {
      "id": "l1c_l1_2_4",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Y para beber?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-2",
        "kind": "S5_DIALOG.carlos",
        "index": 4
      }
    },
    {
      "id": "l1c_l1_2_5",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Quieren algo de postre?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-2",
        "kind": "S5_DIALOG.carlos",
        "index": 5
      }
