    {
      "id": "l1c_l1_5_1",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Qué quiere?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-5",
        "kind": "S5_DIALOG.carlos",
        "index": 1
      }
    },
    {
      "id": "l1c_l1_5_2",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "Son tres euros.",
      "voice": "carlos",
      "source": {
        "chapter": "l1-5",
        "kind": "S5_DIALOG.carlos",
        "index": 2
      }
    },
    {
      "id": "l1c_l1_5_3",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Algo más?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-5",
        "kind": "S5_DIALOG.carlos",
        "index": 3
      }
    },
    {
      "id": "l1c_l1_6_1",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿A qué hora te levantas?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-6",
        "kind": "S5_DIALOG.carlos",
        "index": 1
      }
    },
    {
      "id": "l1c_l1_6_2",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Qué haces por la mañana?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-6",
        "kind": "S5_DIALOG.carlos",
        "index": 2
      }
    },
    {
      "id": "l1c_l1_6_3",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Y por la noche?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-6",
        "kind": "S5_DIALOG.carlos",
        "index": 3
      }
    },
    {
      "id": "l1c_l1_7_1",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Tienes hermanos?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-7",
        "kind": "S5_DIALOG.carlos",
        "index": 1
      }
    },
    {
      "id": "l1c_l1_7_2",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Cómo se llama tu madre?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-7",
        "kind": "S5_DIALOG.carlos",
        "index": 2
      }
    },
    {
      "id": "l1c_l1_7_3",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Y tu padre?",
      "voice": "carlos",
      "source": {
