    {
      "id": "l1c_l1_1_1",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¡Buenas tardes! ¿Qué quieres?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-1",
        "kind": "S5_DIALOG.carlos",
        "index": 1
      }
    },
    {
      "id": "l1c_l1_1_2",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Solo o con leche?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-1",
        "kind": "S5_DIALOG.carlos",
        "index": 2
      }
    },
    {
      "id": "l1c_l1_1_3",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Te traigo también la carta?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-1",
        "kind": "S5_DIALOG.carlos",
        "index": 3
      }
    },
    {
      "id": "l1c_l1_1_4",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "El café está listo. ¡Aquí tienes!",
      "voice": "carlos",
      "source": {
        "chapter": "l1-1",
        "kind": "S5_DIALOG.carlos",
        "index": 4
      }
    },
    {
      "id": "l1c_l1_1_5",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Algo más?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-1",
        "kind": "S5_DIALOG.carlos",
        "index": 5
      }
    },
