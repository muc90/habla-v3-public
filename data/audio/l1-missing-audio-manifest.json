    },
    {
      "id": "l1c_l1_8_1",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Dónde está la estación?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-8",
        "kind": "S5_DIALOG.carlos",
        "index": 1
      }
    },
    {
      "id": "l1c_l1_8_2",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Está lejos el museo?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-8",
        "kind": "S5_DIALOG.carlos",
        "index": 2
      }
    },
    {
