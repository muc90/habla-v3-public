    {
      "id": "l1w_l1_3_de_donde_eres",
      "type": "word",
      "dialect": "es_andalucia",
      "text": "¿de dónde eres?",
      "source": {
        "chapter": "l1-3",
        "kind": "WORDS.es"
      }
    },
    {
      "id": "l1c_l1_3_1",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¡Hola! Buenos días. Soy Carlos.",
      "voice": "carlos",
      "source": {
        "chapter": "l1-3",
        "kind": "S5_DIALOG.carlos",
        "index": 1
      }
    },
    {
      "id": "l1c_l1_3_2",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¡Encantado, Ana! ¿Cómo estás?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-3",
        "kind": "S5_DIALOG.carlos",
        "index": 2
      }
    },
    {
      "id": "l1c_l1_3_3",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "También estoy muy bien, gracias. ¿De dónde eres?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-3",
        "kind": "S5_DIALOG.carlos",
        "index": 3
      }
    },
    {
      "id": "l1c_l1_3_4",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¡Qué bien! Y yo soy de España. ¿Hablas español?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-3",
        "kind": "S5_DIALOG.carlos",
        "index": 4
      }
    },
    {
      "id": "l1c_l1_3_5",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¡Perfecto! Pues, nos vemos, Ana.",
      "voice": "carlos",
      "source": {
        "chapter": "l1-3",
        "kind": "S5_DIALOG.carlos",
        "index": 5
      }
    },
    {
      "id": "l1w_l1_4_vivir",
      "type": "word",
      "dialect": "es_andalucia",
      "text": "vivir",
      "source": {
        "chapter": "l1-4",
        "kind": "WORDS.es"
      }
    },
    {
      "id": "l1w_l1_4_la_cama",
      "type": "word",
      "dialect": "es_andalucia",
      "text": "la cama",
      "source": {
        "chapter": "l1-4",
        "kind": "WORDS.es"
      }
    },
    {
      "id": "l1c_l1_4_1",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Dónde vives?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-4",
        "kind": "S5_DIALOG.carlos",
        "index": 1
      }
    },
    {
      "id": "l1c_l1_4_2",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "¿Qué haces en casa?",
      "voice": "carlos",
      "source": {
        "chapter": "l1-4",
        "kind": "S5_DIALOG.carlos",
        "index": 2
      }
    },
    {
      "id": "l1c_l1_4_3",
      "type": "carlos",
      "dialect": "es_andalucia",
      "text": "Hace calor aquí.",
      "voice": "carlos",
      "source": {
        "chapter": "l1-4",
        "kind": "S5_DIALOG.carlos",
        "index": 3
      }
    },
